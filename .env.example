# Template for .env — committed as documentation. NO real secrets here.
# Copy to .env (`cp .env.example .env`) and fill in real values locally.
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=changeme

# Stage 2 — JWT signing secret. MUST be at least 32 bytes (256 bits) for HS256.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# Added in later stages (kept here so the required keys are documented):
# ANTHROPIC_API_KEY=sk-ant-...                    # Stage 5
